{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake: Configure",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S",
        "${workspaceFolder}",
        "-B",
        "${workspaceFolder}/build_codex_bundle"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "CMake: Build main_qt",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "${workspaceFolder}/build_codex_bundle",
        "--target",
        "main_qt",
        "-j4"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [
        "$gcc"
      ],
      "dependsOn": "CMake: Configure",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "CMake: Build bread_main",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "${workspaceFolder}/build_codex_bundle",
        "--target",
        "bread_main",
        "-j4"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [
        "$gcc"
      ],
      "dependsOn": "CMake: Configure"
    },
    {
      "label": "CMake: Deploy main_qt bundle",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "${workspaceFolder}/build_codex_bundle",
        "--target",
        "deploy_main_qt_bundle",
        "-j4"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [
        "$gcc"
      ],
      "dependsOn": "CMake: Configure"
    }
  ]
}
